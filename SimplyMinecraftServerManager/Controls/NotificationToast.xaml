<UserControl
  x:Class="SimplyMinecraftServerManager.Controls.NotificationToast"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:models="clr-namespace:SimplyMinecraftServerManager.Models"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  x:Name="Root"
  Opacity="0"
  d:DataContext="{d:DesignInstance models:AppNotificationItem}"
  mc:Ignorable="d">
  <UserControl.RenderTransform>
    <TranslateTransform X="28" />
  </UserControl.RenderTransform>
  <Border
    MinWidth="380"
    MaxWidth="440"
    Padding="16"
    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
    BorderBrush="{Binding Appearance, Converter={StaticResource NotificationAppearanceToBorderBrushConverter}}"
    BorderThickness="1"
    CornerRadius="16">
    <Border.Effect>
      <DropShadowEffect BlurRadius="22" Opacity="0.18" ShadowDepth="6" />
    </Border.Effect>
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Border
        Grid.Column="0"
        Width="40"
        Height="40"
        Margin="0,0,14,0"
        Background="{Binding Appearance, Converter={StaticResource NotificationAppearanceToBadgeBrushConverter}}"
        CornerRadius="12"
        VerticalAlignment="Top">
        <ui:SymbolIcon
          Symbol="{Binding Appearance, Converter={StaticResource NotificationAppearanceToSymbolConverter}}"
          FontSize="20"
          Foreground="{Binding Appearance, Converter={StaticResource NotificationAppearanceToForegroundBrushConverter}}"
          HorizontalAlignment="Center"
          VerticalAlignment="Center" />
      </Border>

      <StackPanel Grid.Column="1">
        <TextBlock
          FontSize="15"
          FontWeight="SemiBold"
          Text="{Binding Title}" />
        <TextBlock
          Margin="0,6,0,0"
          FontSize="13"
          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
          Text="{Binding Content}"
          TextWrapping="Wrap" />
      </StackPanel>

      <ui:Button
        Grid.Column="2"
        Width="32"
        Height="32"
        Padding="0"
        Margin="12,-2,-4,0"
        Appearance="Transparent"
        Click="OnCloseClick"
        ToolTip="关闭"
        VerticalAlignment="Top">
        <ui:SymbolIcon Symbol="Dismiss24" FontSize="16" />
      </ui:Button>
    </Grid>
  </Border>
</UserControl>
