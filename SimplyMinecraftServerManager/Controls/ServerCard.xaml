<UserControl x:Class="SimplyMinecraftServerManager.Controls.ServerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SimplyMinecraftServerManager.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:helpers="clr-namespace:SimplyMinecraftServerManager.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="180">
    <UserControl.Resources>
        <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </UserControl.Resources>
    
    <ui:Card VerticalAlignment="Stretch" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 服务器名称和状态 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Server24" FontSize="16"/>
                <TextBlock x:Name="ServerNameText" 
                    Text="{Binding InstanceName, RelativeSource={RelativeSource AncestorType=local:ServerCard}}"
                    VerticalAlignment="Center" 
                    Margin="8,0,0,0"
                    FontWeight="Medium"/>
            </StackPanel>

            <!-- 版本信息 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Text="{Binding ServerType, RelativeSource={RelativeSource AncestorType=local:ServerCard}}" FontSize="11"/>
                <TextBlock Text=" | " FontSize="11"/>
                <TextBlock Text="{Binding MinecraftVersion, RelativeSource={RelativeSource AncestorType=local:ServerCard}}" FontSize="11"/>
            </StackPanel>

            <!-- 操作按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                <ui:Button 
                    Content="启动"
                    Padding="8,4"
                    Click="OnStartClick"
                    IsEnabled="{Binding IsRunning, RelativeSource={RelativeSource AncestorType=local:ServerCard}, Converter={StaticResource InverseBooleanConverter}}"/>
                <ui:Button 
                    Content="停止"
                    Padding="8,4"
                    Margin="4,0,0,0"
                    Click="OnStopClick"
                    IsEnabled="{Binding IsRunning, RelativeSource={RelativeSource AncestorType=local:ServerCard}}"/>
            </StackPanel>
        </Grid>
    </ui:Card>
</UserControl>
