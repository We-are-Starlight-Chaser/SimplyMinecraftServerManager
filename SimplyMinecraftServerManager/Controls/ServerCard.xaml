<UserControl x:Class="SimplyMinecraftServerManager.Controls.ServerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SimplyMinecraftServerManager.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="128" d:DesignWidth="160">
    <ui:Card VerticalAlignment="Stretch">
        <Grid>
            <StackPanel Orientation="Horizontal">
                <ui:FontIcon Glyph="&#xE968;" FontFamily="Segoe Fluent Icons" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                <TextBlock x:Name="ServerName" VerticalAlignment="Top" Margin="5,0,0,0"></TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,40,0,0">
                <ui:Button>启动</ui:Button>
                <ui:Button Margin="5,0,0,0">关闭</ui:Button>
            </StackPanel>
        </Grid>
    </ui:Card>
</UserControl>
