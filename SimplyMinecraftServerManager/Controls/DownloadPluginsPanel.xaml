<UserControl
  x:Class="SimplyMinecraftServerManager.Controls.DownloadPluginsPanel"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  mc:Ignorable="d"
>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid
      Grid.Row="0"
      Visibility="{Binding HasSelectedPluginTarget, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
    >
      <StackPanel>
        <ui:Card Padding="18" Margin="0,0,0,16">
          <StackPanel>
            <TextBlock Text="选择目标实例" FontSize="18" FontWeight="SemiBold" />
            <TextBlock
              Text="{Binding PluginTargetPrompt}"
              Margin="0,8,0,0"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              TextWrapping="Wrap"
            />
          </StackPanel>
        </ui:Card>

        <StackPanel
          HorizontalAlignment="Center"
          Visibility="{Binding PluginTargetInstances.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=inverse}"
        >
          <Border Width="88" Height="88" CornerRadius="22" Background="{DynamicResource SubtleFillColorTertiaryBrush}">
            <ui:SymbolIcon Symbol="Server24" FontSize="40" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
          </Border>
          <TextBlock Text="还没有可用实例" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,18,0,0" />
          <TextBlock
            Text="请先创建服务端实例，再到这里安装插件。"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            HorizontalAlignment="Center"
            Margin="0,8,0,0"
          />
        </StackPanel>
      </StackPanel>
    </Grid>

    <ScrollViewer
      Grid.Row="1"
      VerticalScrollBarVisibility="Auto"
      Visibility="{Binding HasSelectedPluginTarget, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
    >
      <ItemsControl ItemsSource="{Binding PluginTargetInstances}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <ui:Card Width="320" Margin="0,0,16,16" Padding="18">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <Border Width="52" Height="52" CornerRadius="14" Background="{DynamicResource AccentFillColorSecondaryBrush}">
                    <TextBlock Text="{Binding Initial}" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>

                  <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding RunningText}" Margin="0,4,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  </StackPanel>

                  <Border Grid.Column="2" Padding="10,4" CornerRadius="8" Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                    <TextBlock Text="{Binding TargetBadgeText}" FontSize="11" FontWeight="SemiBold" />
                  </Border>
                </Grid>

                <TextBlock Grid.Row="1" Text="{Binding CompatibilityHint}" Margin="0,14,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                <Border Grid.Row="2" Height="1" Margin="0,16,0,16" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

                <ui:Button
                  Grid.Row="3"
                  Command="{Binding DataContext.SelectPluginTargetInstanceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  CommandParameter="{Binding}"
                  Appearance="Primary"
                >
                  <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowRight24" />
                    <TextBlock Text="选择此实例" Margin="8,0,0,0" FontWeight="Medium" />
                  </StackPanel>
                </ui:Button>
              </Grid>
            </ui:Card>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <Grid
      Grid.RowSpan="2"
      Visibility="{Binding HasSelectedPluginTarget, Converter={StaticResource BooleanToVisibilityConverter}}"
    >
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <ui:Card Grid.Row="0" Padding="16" Margin="0,0,0,16">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel>
            <TextBlock Text="{Binding SelectedPluginTargetInstance.Name}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{Binding PluginSearchContextText}" Margin="0,6,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <TextBlock Text="{Binding SelectedPluginTargetInstance.CompatibilityHint}" Margin="0,4,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
          </StackPanel>

          <ui:Button Grid.Column="1" Appearance="Secondary" Command="{Binding SwitchPluginTargetInstanceCommand}" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="ArrowSync24" />
              <TextBlock Text="切换实例" Margin="8,0,0,0" FontWeight="Medium" />
            </StackPanel>
          </ui:Button>
        </Grid>
      </ui:Card>

      <Grid Grid.Row="1" Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ui:TextBox
          Grid.Column="0"
          Text="{Binding PluginSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
          PlaceholderText="搜索插件..."
          KeyDown="OnPluginSearchKeyDown"
        />

        <ui:Button Grid.Column="1" Command="{Binding SearchPluginsCommand}" Margin="8,0,0,0" IsEnabled="{Binding IsSearchingPlugins, Converter={StaticResource InverseBooleanConverter}}">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Search24" />
            <TextBlock Text="搜索" Margin="8,0,0,0" FontWeight="Medium" />
          </StackPanel>
        </ui:Button>

        <Grid Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsSearchingPlugins, Converter={StaticResource BooleanToVisibilityConverter}}">
          <ui:ProgressRing Width="18" Height="18" IsIndeterminate="True" />
        </Grid>
      </Grid>

      <Grid Grid.Row="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding PluginSearchStatus}" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <ItemsControl ItemsSource="{Binding PluginSearchResults}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <ui:Card Margin="0,0,0,14" Padding="14">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="200" />
                      </Grid.ColumnDefinitions>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>

                      <Border Grid.RowSpan="4" Width="60" Height="60" CornerRadius="16" Background="{DynamicResource AccentFillColorSecondaryBrush}" Margin="0,0,14,0" ClipToBounds="True">
                        <Grid>
                          <Image
                            Source="{Binding IconUrl}"
                            Stretch="UniformToFill"
                            Visibility="{Binding HasIcon, Converter={StaticResource BooleanToVisibilityConverter}}"
                          />
                          <TextBlock
                            Text="{Binding Initial}"
                            Foreground="White"
                            FontSize="28"
                            FontWeight="Bold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasIcon, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                          />
                        </Grid>
                      </Border>

                      <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding Author, StringFormat=作者：{0}}" Margin="10,0,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                      </Grid>

                      <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding Description}" Margin="0,8,0,0" TextWrapping="Wrap" MaxHeight="52" />

                      <WrapPanel Grid.Column="1" Grid.Row="2" Margin="0,10,0,0">
                        <Border Background="{DynamicResource AccentFillColorDefaultBrush}" CornerRadius="7" Padding="10,5" Margin="0,0,8,6">
                          <TextBlock Text="{Binding DownloadsText, StringFormat=下载 {0}}" Foreground="White" FontSize="11" />
                        </Border>
                        <Border Background="{DynamicResource SystemFillColorCautionBrush}" CornerRadius="7" Padding="10,5" Margin="0,0,8,6">
                          <TextBlock Text="{Binding FollowsText, StringFormat=关注 {0}}" Foreground="White" FontSize="11" />
                        </Border>
                        <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}" CornerRadius="7" Padding="10,5" Margin="0,0,8,6">
                          <TextBlock Text="{Binding CompatibilityText}" FontSize="11" />
                        </Border>
                      </WrapPanel>

                      <StackPanel Grid.Column="2" Grid.RowSpan="4" Margin="14,0,0,0" VerticalAlignment="Center">
                        <ui:Button
                          Command="{Binding DataContext.DownloadPluginCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}"
                          Appearance="Primary"
                          Margin="0,0,0,8"
                          IsEnabled="{Binding DataContext.IsLoadingPluginVersions, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBooleanConverter}}"
                        >
                          <Grid>
                            <StackPanel
                              Orientation="Horizontal"
                              Visibility="{Binding DataContext.IsLoadingPluginVersions, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                            >
                              <ui:SymbolIcon Symbol="ArrowDownload24" />
                              <TextBlock Text="选择版本并安装" Margin="8,0,0,0" FontWeight="Medium" />
                            </StackPanel>
                            <StackPanel
                              Orientation="Horizontal"
                              Visibility="{Binding DataContext.IsLoadingPluginVersions, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                            >
                              <ui:ProgressRing Width="14" Height="14" IsIndeterminate="True" />
                              <TextBlock Text="加载中..." Margin="8,0,0,0" FontWeight="Medium" />
                            </StackPanel>
                          </Grid>
                        </ui:Button>

                        <ui:Button
                          Command="{Binding DataContext.SavePluginAsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}"
                          Appearance="Secondary"
                          IsEnabled="{Binding DataContext.IsLoadingPluginVersions, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBooleanConverter}}"
                        >
                          <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Save24" />
                            <TextBlock Text="选择版本并另存为" Margin="8,0,0,0" FontWeight="Medium" />
                          </StackPanel>
                        </ui:Button>
                      </StackPanel>
                    </Grid>
                  </ui:Card>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding PluginSearchResults.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=inverse}">
              <Border Width="82" Height="82" CornerRadius="22" Background="{DynamicResource SubtleFillColorTertiaryBrush}">
                <ui:SymbolIcon Symbol="Search24" FontSize="36" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
              </Border>
              <TextBlock Text="还没有搜索结果" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,18,0,0" />
              <TextBlock
                Text="输入关键词后开始搜索，结果会自动按当前实例的服务端类型和版本过滤。"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center"
                Margin="0,8,0,0"
                TextWrapping="Wrap"
                TextAlignment="Center"
              />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,16,0,0" Visibility="{Binding HasMorePlugins, Converter={StaticResource BooleanToVisibilityConverter}}">
          <ui:Button Command="{Binding LoadMorePluginsCommand}" IsEnabled="{Binding IsLoadingMorePlugins, Converter={StaticResource InverseBooleanConverter}}" HorizontalAlignment="Center" Appearance="Secondary">
            <Grid>
              <StackPanel Orientation="Horizontal" Visibility="{Binding IsLoadingMorePlugins, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <ui:SymbolIcon Symbol="Add24" />
                <TextBlock Text="加载更多插件" Margin="8,0,0,0" />
              </StackPanel>
              <ui:ProgressRing Width="16" Height="16" IsIndeterminate="True" Visibility="{Binding IsLoadingMorePlugins, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
          </ui:Button>
        </Grid>

        <Grid
          Grid.RowSpan="3"
          Panel.ZIndex="20"
          Visibility="{Binding IsLoadingPluginVersions, Converter={StaticResource BooleanToVisibilityConverter}}"
        >
          <Border Background="#66000000" CornerRadius="12" />
          <Border
            Width="320"
            Padding="20"
            CornerRadius="14"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
          >
            <StackPanel>
              <ui:ProgressRing Width="36" Height="36" IsIndeterminate="True" HorizontalAlignment="Center" />
              <TextBlock
                Text="正在准备版本列表"
                FontSize="17"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"
                Margin="0,14,0,0"
              />
              <TextBlock
                Text="{Binding PluginVersionLoadingMessage}"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap"
                TextAlignment="Center"
                Margin="0,8,0,0"
              />
            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
