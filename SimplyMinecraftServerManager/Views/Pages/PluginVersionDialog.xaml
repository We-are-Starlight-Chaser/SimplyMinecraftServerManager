<ui:ContentDialog
  x:Class="SimplyMinecraftServerManager.Views.Pages.PluginVersionDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:viewModels="clr-namespace:SimplyMinecraftServerManager.ViewModels.Dialogs"
  Title="选择插件版本"
  MaxWidth="980"
  MinWidth="860"
  HorizontalAlignment="Center"
  VerticalAlignment="Center"
  Background="{DynamicResource ApplicationBackgroundBrush}"
  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
  BorderThickness="1"
  d:DataContext="{d:DesignInstance viewModels:PluginVersionDialogViewModel, IsDesignTimeCreatable=False}"
  d:DesignHeight="640"
  d:DesignWidth="960"
  mc:Ignorable="d"
>
  <Border
    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
    CornerRadius="8"
    Padding="24"
    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
    BorderThickness="1"
  >
    <Grid MinWidth="780">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Margin="0,0,0,20">
        <StackPanel>
          <TextBlock Text="{Binding ProjectTitle}" FontSize="24" FontWeight="SemiBold" />
          <TextBlock
            Text="{Binding TargetDescription}"
            Margin="0,8,0,0"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            TextWrapping="Wrap"
          />
        </StackPanel>
      </Grid>

      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="340" />
          <ColumnDefinition Width="16" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
          Grid.Column="0"
          Background="{DynamicResource SubtleFillColorSecondaryBrush}"
          CornerRadius="12"
          Padding="8"
        >
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="可用版本" FontSize="16" FontWeight="SemiBold" Margin="8,4,8,12" />

            <ListBox
              Grid.Row="1"
              ItemsSource="{Binding Versions}"
              SelectedItem="{Binding SelectedVersionItem, Mode=TwoWay}"
              BorderThickness="0"
              Background="Transparent"
              ScrollViewer.VerticalScrollBarVisibility="Auto"
              MinHeight="360"
            >
              <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type viewModels:PluginVersionListItem}">
                  <Border Padding="12" Margin="0,0,0,8" CornerRadius="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>

                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding VersionNumber}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <Border Grid.Column="1" CornerRadius="8" Padding="8,3" Background="{DynamicResource SubtleFillColorTertiaryBrush}">
                          <TextBlock Text="{Binding VersionTypeText}" FontSize="11" />
                        </Border>
                      </Grid>

                      <TextBlock
                        Grid.Row="1"
                        Text="{Binding Name}"
                        Margin="0,6,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        TextTrimming="CharacterEllipsis"
                      />

                      <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="{Binding PublishedText}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="  •  " FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <TextBlock Text="{Binding DownloadsText, StringFormat='下载 {0}'}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="2" Margin="0,12,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock
                Text="{Binding VersionLoadStatus}"
                Margin="0,0,0,8"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center"
              />

              <ui:Button
                Grid.Row="1"
                Command="{Binding LoadMoreVersionsCommand}"
                HorizontalAlignment="Stretch"
                Appearance="Secondary"
                Visibility="{Binding HasMoreVersions, Converter={StaticResource BooleanToVisibilityConverter}}"
              >
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <ui:SymbolIcon Symbol="Add24" />
                  <TextBlock Text="加载更多版本" Margin="8,0,0,0" />
                </StackPanel>
              </ui:Button>
            </Grid>
          </Grid>
        </Border>

        <Border
          Grid.Column="2"
          Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
          CornerRadius="12"
          Padding="18"
          BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
          BorderThickness="1"
        >
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel DataContext="{Binding SelectedVersionItem}">
              <TextBlock Text="版本详情" FontSize="16" FontWeight="SemiBold" />
              <TextBlock
                Text="{Binding VersionNumber}"
                Margin="0,16,0,0"
                FontSize="28"
                FontWeight="Bold"
                TextWrapping="Wrap"
              />
              <TextBlock
                Text="{Binding Name}"
                Margin="0,6,0,0"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap"
              />

              <WrapPanel Margin="0,16,0,0">
                <Border Margin="0,0,8,8" Padding="10,6" CornerRadius="8" Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                  <TextBlock Text="{Binding PublishedText}" FontSize="12" />
                </Border>
                <Border Margin="0,0,8,8" Padding="10,6" CornerRadius="8" Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                  <TextBlock Text="{Binding DownloadsText, StringFormat='下载 {0}'}" FontSize="12" />
                </Border>
                <Border Margin="0,0,8,8" Padding="10,6" CornerRadius="8" Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                  <TextBlock Text="{Binding VersionTypeText}" FontSize="12" />
                </Border>
              </WrapPanel>

              <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="16" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:Card Grid.Column="0" Padding="14">
                  <StackPanel>
                    <TextBlock Text="主文件" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileName}" Margin="0,10,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding FileSizeBytes, Converter={StaticResource FileSizeConverter}}" Margin="0,6,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  </StackPanel>
                </ui:Card>

                <ui:Card Grid.Column="2" Padding="14">
                  <StackPanel>
                    <TextBlock Text="兼容范围" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LoadersText}" Margin="0,10,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding GameVersionsText}" Margin="0,6,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                </ui:Card>
              </Grid>

              <ui:Card Padding="14" Margin="0,16,0,0">
                <StackPanel>
                  <TextBlock Text="更新说明" FontWeight="SemiBold" />
                  <TextBox
                    Margin="0,10,0,0"
                    IsReadOnly="True"
                    Text="{Binding ChangelogPreview, Mode=OneWay}"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto"
                    MinHeight="220"
                    BorderThickness="0"
                    Background="Transparent"
                  />
                </StackPanel>
              </ui:Card>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
        <ui:Button Appearance="Secondary" Margin="0,0,10,0" Click="OnCloseButtonClick">取消</ui:Button>
        <ui:Button Appearance="Primary" Click="OnPrimaryButtonClick" IsEnabled="{Binding HasVersions}">
          <TextBlock Text="{Binding ConfirmButtonText}" />
        </ui:Button>
      </StackPanel>
    </Grid>
  </Border>
</ui:ContentDialog>
