<Page
  x:Class="SimplyMinecraftServerManager.Views.Pages.InstancePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="实例管理"
  d:DataContext="{d:DesignInstance local:InstancePage, IsDesignTimeCreatable=False}"
  d:DesignHeight="600"
  d:DesignWidth="900"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
  x:Name="PageRoot"
>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="16,16,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding ViewModel.InstanceName, ElementName=PageRoot}" FontSize="24" FontWeight="Medium" VerticalAlignment="Center"/>
                    <!-- 状态指示器 - 运行中 -->
                    <Border Background="#4CAF50" CornerRadius="4" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center"
                        Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="运行中" FontSize="12" Foreground="White" FontWeight="Medium"/>
                    </Border>
                    <!-- 状态指示器 - 已停止 -->
                    <Border Background="#9E9E9E" CornerRadius="4" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center"
                        Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <TextBlock Text="已停止" FontSize="12" Foreground="White" FontWeight="Medium"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <!-- 服务端类型标签 -->
                    <Border Background="#B388FF" CornerRadius="4" Padding="8,2">
                        <TextBlock Text="{Binding ViewModel.ServerType}" FontSize="12" Foreground="White" FontWeight="Medium"/>
                    </Border>
                    <!-- 版本标签 -->
                    <Border Background="#B388FF" CornerRadius="4" Padding="8,2" Margin="8,0,0,0">
                        <TextBlock Text="{Binding ViewModel.MinecraftVersion, ElementName=PageRoot}" FontSize="12" Foreground="White" FontWeight="Medium"/>
                    </Border>
                    <TextBlock Text="{Binding ViewModel.InstanceId, ElementName=PageRoot}" 
                        FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" 
                        Margin="12,0,0,0" VerticalAlignment="Center" FontFamily="Consolas"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <!-- 启动按钮 - 未运行时显示 -->
                <ui:Button 
                    Command="{Binding ViewModel.StartServerCommand, ElementName=PageRoot}"
                    Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                    Appearance="Success" Margin="0,0,5,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Play24"/>
                        <TextBlock Text="启动" Margin="8,0,0,0"/>
                    </StackPanel>
                </ui:Button>
                <!-- 停止按钮 - 运行时显示 -->
                <ui:Button 
                    Command="{Binding ViewModel.StopServerCommand, ElementName=PageRoot}"
                    Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Appearance="Caution"
                    Margin="0,0,5,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Stop24"/>
                        <TextBlock Text="停止" Margin="8,0,0,0"/>
                    </StackPanel>
                </ui:Button>
                <!-- 终止按钮 - 运行时显示 -->
                <ui:Button 
                    Command="{Binding ViewModel.TerminateServerCommand, ElementName=PageRoot}"
                    Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Appearance="Danger"
                    ToolTipService.ToolTip="强制终止服务器进程！小心！这样可能丢失所有未保存进度！">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Dismiss24"/>
                        <TextBlock Text="终止" Margin="8,0,0,0"/>
                    </StackPanel>
                </ui:Button>
            </StackPanel>
        </Grid>

        <!-- 主内容区域 -->
        <TabControl Grid.Row="1" Margin="16,16,16,0" SelectionChanged="OnTabSelectionChanged">
            <!-- 控制台 -->
            <TabItem Header="控制台">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 控制台工具栏 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:Button
                            Command="{Binding ViewModel.ClearConsoleCommand, ElementName=PageRoot}"
                            Appearance="Secondary"
                            Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                                <TextBlock Text="清空" Margin="4,0,0,0" FontSize="12"/>
                            </StackPanel>
                        </ui:Button>
                        <ui:Button
                            Command="{Binding ViewModel.CopyConsoleCommand, ElementName=PageRoot}"
                            Appearance="Secondary"
                            Padding="8,4"
                            Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Copy24" FontSize="14"/>
                                <TextBlock Text="复制全部" Margin="4,0,0,0" FontSize="12"/>
                            </StackPanel>
                        </ui:Button>
                        <CheckBox
                            IsChecked="{Binding ViewModel.AutoScroll, ElementName=PageRoot, Mode=TwoWay}"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center">
                            自动滚动
                        </CheckBox>
                    </StackPanel>

                    <!-- 控制台输出区域 - 使用 FlowDocumentScrollViewer 支持选择和复制 -->
                    <Border Grid.Row="1"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="1" Name="FlowDocumentScrollViewerBorder">
                        <FlowDocumentScrollViewer
                            x:Name="ConsoleScrollViewer"
                            HorizontalScrollBarVisibility="Visible"
                            VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Visible">
                            <FlowDocument
                                x:Name="ConsoleDocument"
                                FontFamily="Consolas"
                                FontSize="12"
                                PageWidth="9999"
                                PageHeight="376"
                                LineHeight="18">
                                <Paragraph
                                    x:Name="ConsoleParagraph"
                                    Margin="8,4"
                                    FontFamily="Consolas"
                                    FontSize="12"/>
                            </FlowDocument>
                        </FlowDocumentScrollViewer>
                    </Border>

                    <!-- 命令输入区域 -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ui:TextBox Grid.Column="0"
                            Text="{Binding ViewModel.CommandInput, ElementName=PageRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="输入命令..."
                            KeyDown="OnCommandKeyDown"
                            IsEnabled="{Binding ViewModel.IsRunning, ElementName=PageRoot}"/>

                        <ui:Button Grid.Column="1"
                            Command="{Binding ViewModel.SendCommandCommand, ElementName=PageRoot}"
                            Margin="8,0,0,0"
                            IsEnabled="{Binding ViewModel.IsRunning, ElementName=PageRoot}">
                            发送
                        </ui:Button>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- 性能监控 -->
            <TabItem Header="性能" x:Name="PerformanceTabItem">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 实时指标卡片 -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- CPU 使用率 -->
                        <ui:Card Grid.Column="0" Padding="16" Margin="0,0,8,0" MinHeight="120">
                            <Grid>
                                <!-- 运行时显示 -->
                                <StackPanel Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Gauge24" FontSize="24" Foreground="#00BCD4"/>
                                        <TextBlock Text="CPU 使用率" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock
                                        Text="{Binding ViewModel.CpuUsage, StringFormat='{}{0:F1} %'}"
                                        FontSize="32"
                                        FontWeight="Bold"
                                        Margin="0,8,0,0"/>
                                    <ProgressBar
                                        Value="{Binding ViewModel.CpuUsage, Mode=OneWay}"
                                        Maximum="100"
                                        Height="4"
                                        Margin="0,8,0,0"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        Foreground="#00BCD4"/>
                                </StackPanel>
                                <!-- 停止时显示 -->
                                <StackPanel Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Gauge24" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock Text="请启动后查看" Margin="0,8,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </ui:Card>

                        <!-- 内存使用 -->
                        <ui:Card Grid.Column="1" Padding="16" Margin="4,0,4,0" MinHeight="120">
                            <Grid>
                                <!-- 运行时显示 -->
                                <StackPanel Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="24" Foreground="#7C4DFF"/>
                                        <TextBlock Text="内存使用" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock
                                        Text="{Binding ViewModel.MemoryUsage, ElementName=PageRoot, StringFormat='{}{0:F0} MB'}"
                                        FontSize="32"
                                        FontWeight="Bold"
                                        Margin="0,8,0,0"/>
                                    <ProgressBar
                                        Value="{Binding ViewModel.MemoryUsage,Mode=OneWay}"
                                        Maximum="{Binding ViewModel.MaxMemoryMb,Mode=OneWay}"
                                        Height="4"
                                        Margin="0,8,0,0"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        Foreground="#7C4DFF"/>
                                </StackPanel>
                                <!-- 停止时显示 -->
                                <StackPanel Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock Text="请启动后查看" Margin="0,8,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </ui:Card>

                        <!-- 存储空间 -->
                        <ui:Card Grid.Column="2" Padding="16" Margin="8,0,0,0" VerticalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="总存储" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock
                                    Text="{Binding ViewModel.TotalStorage, ElementName=PageRoot}"
                                    FontSize="32"
                                    FontWeight="Bold"
                                    Margin="0,8,0,0"/>
                            </StackPanel>
                        </ui:Card>
                    </Grid>

                    <!-- 世界文件夹详情 -->
                    <ui:Card Grid.Row="1" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                Text="世界文件夹占用"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Margin="0,0,0,12"/>

                            <ListView Grid.Row="1"
                                ItemsSource="{Binding ViewModel.WorldStorageInfo, ElementName=PageRoot}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                Text="{Binding WorldName}"
                                                VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="1"
                                                Text="{Binding SizeFormatted}"
                                                FontFamily="Consolas"
                                                VerticalAlignment="Center"
                                                Margin="16,0"/>

                                            <ProgressBar Grid.Column="2"
                                                Value="{Binding SizePercent}"
                                                Maximum="100"
                                                Height="6"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </ui:Card>
                </Grid>
            </TabItem>

            <!-- 插件管理 -->
            <TabItem Header="插件">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="已安装插件" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
                        <ui:Button 
                            Command="{Binding ViewModel.RefreshPluginsCommand, ElementName=PageRoot}"
                            Margin="16,0,0,0"
                            Appearance="Secondary">
                            <ui:SymbolIcon Symbol="ArrowSync24"/>
                        </ui:Button>
                        <ui:Button Margin="16,0,0,0" Command="{Binding ViewModel.AddPluginCommand}">
                            <ui:SymbolIcon Symbol="AddCircle24"/>
                        </ui:Button>
                    </StackPanel>

                    <ListView Grid.Row="1" ItemsSource="{Binding ViewModel.Plugins, ElementName=PageRoot}"
                        VirtualizingStackPanel.IsVirtualizing="True"
                        VirtualizingStackPanel.VirtualizationMode="Recycling"
                        ScrollViewer.IsDeferredScrollingEnabled="True">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="Medium"/>
                                            <TextBlock Text=" v"/>
                                            <TextBlock Text="{Binding Version}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" FontSize="12" MaxHeight="40" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Authors}" FontSize="11"/>
                                    </StackPanel>

                                    <ui:Button Grid.Column="1" 
                                        Command="{Binding ViewModel.DeletePluginCommand, ElementName=PageRoot}"
                                        CommandParameter="{Binding}"
                                        Appearance="Secondary">
                                        <ui:SymbolIcon Symbol="Delete24"/>
                                    </ui:Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- 服务器配置 -->
            <TabItem Header="配置">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="服务器设置" FontSize="16" FontWeight="Medium" Margin="0,0,0,12"/>

                    <ScrollViewer Grid.Row="1">
                        <StackPanel>
                            <ui:Card Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="内存设置" FontWeight="Medium" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="最小内存 (MB)" Margin="0,0,0,4"/>
                                            <ui:TextBox Text="{Binding ViewModel.EditMinMemory, ElementName=PageRoot, Mode=TwoWay}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="最大内存 (MB)" Margin="0,0,0,4"/>
                                            <ui:TextBox Text="{Binding ViewModel.EditMaxMemory, ElementName=PageRoot, Mode=TwoWay}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ui:Card>

                            <ui:Card Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="JDK 路径" FontWeight="Medium" Margin="0,0,0,8"/>
                                    <ui:TextBox Text="{Binding ViewModel.EditJdkPath, ElementName=PageRoot, Mode=TwoWay}" 
                                        PlaceholderText="留空使用全局默认 JDK"/>
                                </StackPanel>
                            </ui:Card>

                            <ui:Button 
                                Command="{Binding ViewModel.SaveSettingsCommand, ElementName=PageRoot}"
                                Appearance="Primary"
                                HorizontalAlignment="Left">
                                保存设置
                            </ui:Button>
                            <ui:Button Command="{Binding ViewModel.OpenServerFolderCommand}" Margin="0,5,0,0">打开版本文件夹</ui:Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- server.properties -->
            <TabItem Header="server.properties">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="server.properties" FontSize="16" FontWeight="Medium" Margin="0,0,0,12"/>

                    <DataGrid Grid.Row="1"
                        ItemsSource="{Binding ViewModel.ServerProperties, ElementName=PageRoot}"
                        AutoGenerateColumns="False"
                        IsReadOnly="False"
                        CanUserAddRows="True"
                        CanUserDeleteRows="True"
                        GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="属性名" Binding="{Binding Key, Mode=OneWay}" Width="*"/>
                            <DataGridTemplateColumn Header="值" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Value,Mode=TwoWay}"></TextBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>