<Page
  x:Class="SimplyMinecraftServerManager.Views.Pages.InstancePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:helpers="clr-namespace:SimplyMinecraftServerManager.Helpers"
  Title="实例管理"
  d:DataContext="{d:DesignInstance local:InstancePage, IsDesignTimeCreatable=False}"
  d:DesignHeight="600"
  d:DesignWidth="900"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
  x:Name="PageRoot"
>
    <Page.Resources>
        <helpers:BooleanToEnableTextConverter x:Key="BooleanToEnableTextConverter"/>
        <helpers:BooleanToAppearanceConverter x:Key="BooleanToAppearanceConverter"/>
        <DataTemplate x:Key="PluginTabHeaderTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="插件管理" VerticalAlignment="Center"/>
                <Border Grid.Column="1" 
                        Background="{DynamicResource AccentFillColorDefaultBrush}" 
                        CornerRadius="10" 
                        Padding="6,2" 
                        Margin="6,0,0,0">
                    <TextBlock Text="{Binding ViewModel.Plugins.Count, ElementName=PageRoot}" 
                               Foreground="White" 
                               FontSize="10" 
                               FontWeight="Medium"/>
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="16,8,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding ViewModel.InstanceName, ElementName=PageRoot}" FontSize="24" FontWeight="Medium" VerticalAlignment="Center"/>
                    <!-- 状态指示器 - 运行中 -->
                    <Border Background="#4CAF50" CornerRadius="4" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center"
                        Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="运行中" FontSize="12" Foreground="White" FontWeight="Medium"/>
                    </Border>
                    <!-- 状态指示器 - 已停止 -->
                    <Border Background="#9E9E9E" CornerRadius="4" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center"
                        Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <TextBlock Text="已停止" FontSize="12" Foreground="White" FontWeight="Medium"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <!-- 服务端类型标签 -->
                    <Border Background="#B388FF" CornerRadius="4" Padding="8,2">
                        <TextBlock Text="{Binding ViewModel.ServerType}" FontSize="12" Foreground="White" FontWeight="Medium"/>
                    </Border>
                    <!-- 版本标签 -->
                    <Border Background="#B388FF" CornerRadius="4" Padding="8,2" Margin="8,0,0,0">
                        <TextBlock Text="{Binding ViewModel.MinecraftVersion, ElementName=PageRoot}" FontSize="12" Foreground="White" FontWeight="Medium"/>
                    </Border>
                    <TextBlock Text="{Binding ViewModel.InstanceId, ElementName=PageRoot}" 
                        FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" 
                        Margin="12,0,0,0" VerticalAlignment="Center" FontFamily="Consolas"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <!-- 启动按钮 - 未运行时显示 -->
                <ui:Button 
                    Command="{Binding ViewModel.StartServerCommand, ElementName=PageRoot}"
                    Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                    Appearance="Success" Margin="0,0,5,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Play24"/>
                        <TextBlock Text="启动" Margin="8,0,0,0"/>
                    </StackPanel>
                </ui:Button>
                <!-- 停止按钮 - 运行时显示 -->
                <ui:Button 
                    Command="{Binding ViewModel.StopServerCommand, ElementName=PageRoot}"
                    Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Appearance="Caution"
                    Margin="0,0,5,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Stop24"/>
                        <TextBlock Text="停止" Margin="8,0,0,0"/>
                    </StackPanel>
                </ui:Button>
                <!-- 终止按钮 - 运行时显示 -->
                <ui:Button 
                    Command="{Binding ViewModel.TerminateServerCommand, ElementName=PageRoot}"
                    Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Appearance="Danger"
                    ToolTipService.ToolTip="强制终止服务器进程！小心！这样可能丢失所有未保存进度！">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Dismiss24"/>
                        <TextBlock Text="终止" Margin="8,0,0,0"/>
                    </StackPanel>
                </ui:Button>
            </StackPanel>
        </Grid>

        <!-- 主内容区域 -->
        <TabControl Grid.Row="1" Margin="0,8,0,0" SelectionChanged="OnTabSelectionChanged">
            <!-- 仪表盘 -->
            <TabItem Header="仪表盘" x:Name="DashboardTabItem">
                <ScrollViewer Margin="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <!-- 服务器基本信息卡片 -->
                        <ui:Card Margin="0,0,0,16" Padding="16">
                            <StackPanel>
                                <TextBlock Text="服务器信息" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                        <TextBlock Text="游戏模式" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{Binding ViewModel.GameMode, ElementName=PageRoot}" 
                                            FontSize="14" FontWeight="Medium" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                                        <TextBlock Text="在线模式" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{Binding ViewModel.IsOnlineMode, ElementName=PageRoot, StringFormat='{}{0}'}" 
                                            FontSize="14" FontWeight="Medium" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                                        <TextBlock Text="模拟距离" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{Binding ViewModel.SimulationDistance, ElementName=PageRoot, StringFormat='{}{0} 区块'}" 
                                            FontSize="14" FontWeight="Medium" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8">
                                        <TextBlock Text="视距" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{Binding ViewModel.ViewDistance, ElementName=PageRoot, StringFormat='{}{0} 区块'}" 
                                            FontSize="14" FontWeight="Medium" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" Grid.ColumnSpan="2">
                                        <TextBlock Text="服务器地址" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding ViewModel.ServerAddress, ElementName=PageRoot}" 
                                                FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                            <ui:Button 
                                                Command="{Binding ViewModel.CopyServerAddressCommand, ElementName=PageRoot}"
                                                Margin="8,0,0,0" 
                                                Appearance="Secondary"
                                                Padding="8,2">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Copy24" FontSize="12"/>
                                                    <TextBlock Text="复制" Margin="4,0,0,0" FontSize="12"/>
                                                </StackPanel>
                                            </ui:Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ui:Card>

                        <!-- 在线玩家信息卡片 -->
                        <ui:Card Margin="0,0,0,16" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="在线玩家" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ViewModel.OnlinePlayersCount, ElementName=PageRoot}" 
                                        FontSize="16" FontWeight="SemiBold" 
                                        Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                        Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="/" Margin="4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ViewModel.MaxPlayersCount, ElementName=PageRoot}" 
                                        FontSize="16" FontWeight="SemiBold" 
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"/>
                                </StackPanel>

                                <ListView Grid.Row="2" 
                                    ItemsSource="{Binding ViewModel.OnlinePlayers, ElementName=PageRoot}"
                                    BorderThickness="0"
                                    MaxHeight="200">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderThickness="0" Padding="8" CornerRadius="4" 
                                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" (ID: " FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Id}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBlock Text=")" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" [OP]" FontSize="11" Foreground="#FFC107" FontWeight="Bold" 
                                                            Visibility="{Binding IsOp, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                                            Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <ui:Button 
                                                            Command="{Binding DataContext.ViewModel.SetPlayerAsOpCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Content="设为OP"
                                                            Margin="4,0,0,0"
                                                            Appearance="Secondary"
                                                            Padding="8,2"
                                                            FontSize="11"
                                                            Visibility="{Binding IsOp, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                                        <ui:Button 
                                                            Command="{Binding DataContext.ViewModel.RemovePlayerOpCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Content="取消OP"
                                                            Margin="4,0,0,0"
                                                            Appearance="Secondary"
                                                            Padding="8,2"
                                                            FontSize="11"
                                                            Visibility="{Binding IsOp, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                        <ui:Button 
                                                            Command="{Binding DataContext.ViewModel.KickPlayerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Content="踢出"
                                                            Margin="4,0,0,0"
                                                            Appearance="Caution"
                                                            Padding="8,2"
                                                            FontSize="11"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </ui:Card>

                        <!-- 性能监控卡片 -->
                        <ui:Card Margin="0,0,0,16" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="性能监控" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ViewModel.Uptime, ElementName=PageRoot, StringFormat='已运行 {0}'}" 
                                        FontSize="14" FontWeight="Medium" 
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Margin="16,0,0,0" VerticalAlignment="Center"/>
                                    <ui:Button 
                                        Command="{Binding ViewModel.RefreshDashboardCommand, ElementName=PageRoot}"
                                        Margin="16,0,0,0" 
                                        Appearance="Secondary"
                                        Padding="8,2">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="ArrowSync24" FontSize="12"/>
                                            <TextBlock Text="刷新" Margin="4,0,0,0" FontSize="12"/>
                                        </StackPanel>
                                    </ui:Button>
                                </StackPanel>

                                <Grid Grid.Row="1" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- CPU 使用率 -->
                                    <ui:Card Grid.Column="0" Padding="16" Margin="0,0,8,0" MinHeight="120">
                                        <Grid>
                                            <!-- 运行时显示 -->
                                            <StackPanel Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Gauge24" FontSize="24" Foreground="#00BCD4"/>
                                                    <TextBlock Text="CPU 使用率" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock
                                                    Text="{Binding ViewModel.CpuUsage, StringFormat='{}{0:F1} %', ElementName=PageRoot}"
                                                    FontSize="32"
                                                    FontWeight="Bold"
                                                    Margin="0,8,0,0"/>
                                                <ProgressBar
                                                    Value="{Binding ViewModel.CpuUsage, Mode=OneWay, ElementName=PageRoot}"
                                                    Maximum="100"
                                                    Height="4"
                                                    Margin="0,8,0,0"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                    Foreground="#00BCD4"/>
                                            </StackPanel>
                                            <!-- 停止时显示 -->
                                            <StackPanel Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                                <ui:SymbolIcon Symbol="Gauge24" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                <TextBlock Text="请启动后查看" Margin="0,8,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </ui:Card>

                                    <!-- 内存使用 -->
                                    <ui:Card Grid.Column="1" Padding="16" Margin="4,0,4,0" MinHeight="120">
                                        <Grid>
                                            <!-- 运行时显示 -->
                                            <StackPanel Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="24" Foreground="#7C4DFF"/>
                                                    <TextBlock Text="内存使用" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock
                                                    Text="{Binding ViewModel.MemoryUsage, ElementName=PageRoot, StringFormat='{}{0:F0} MB'}"
                                                    FontSize="32"
                                                    FontWeight="Bold"
                                                    Margin="0,8,0,0"/>
                                                <ProgressBar
                                                    Value="{Binding ViewModel.MemoryUsage, Mode=OneWay, ElementName=PageRoot}"
                                                    Maximum="{Binding ViewModel.MaxMemoryMb, Mode=OneWay}"
                                                    Height="4"
                                                    Margin="0,8,0,0"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                    Foreground="#7C4DFF"/>
                                            </StackPanel>
                                            <!-- 停止时显示 -->
                                            <StackPanel Visibility="{Binding ViewModel.IsRunning, ElementName=PageRoot, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                                <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                <TextBlock Text="请启动后查看" Margin="0,8,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </ui:Card>

                                    <!-- 存储空间 -->
                                    <ui:Card Grid.Column="2" Padding="16" Margin="8,0,0,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="HardDrive24" FontSize="24" Foreground="#4CAF50"/>
                                                <TextBlock Text="总存储" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock
                                                Text="{Binding ViewModel.TotalStorage, ElementName=PageRoot}"
                                                FontSize="32"
                                                FontWeight="Bold"
                                                Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </ui:Card>
                                </Grid>

                                <!-- 世界文件夹详情 -->
                                <ui:Card Grid.Row="2" Padding="16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                            Text="世界文件夹占用"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Margin="0,0,0,12"/>

                                        <ListView Grid.Row="1"
                                            ItemsSource="{Binding ViewModel.WorldStorageInfo, ElementName=PageRoot}"
                                            BorderThickness="0">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="120"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                            Text="{Binding WorldName}"
                                                            VerticalAlignment="Center"/>

                                                        <TextBlock Grid.Column="1"
                                                            Text="{Binding SizeFormatted}"
                                                            FontFamily="Consolas"
                                                            VerticalAlignment="Center"
                                                            Margin="16,0"/>

                                                        <ProgressBar Grid.Column="2"
                                                            Value="{Binding SizePercent}"
                                                            Maximum="100"
                                                            Height="6"
                                                            VerticalAlignment="Center"
                                                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                            Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>
                                </ui:Card>
                            </Grid>
                        </ui:Card>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 控制台 -->
            <TabItem Header="控制台">
                <Grid>
                    <Grid Name="FlowDocumentScrollViewerGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <FlowDocumentScrollViewer
                                x:Name="ConsoleScrollViewer"
                                HorizontalScrollBarVisibility="Visible"
                                VerticalScrollBarVisibility="Auto"
                                MaxHeight="{Binding Path=ActualHeight,ElementName=FlowDocumentScrollViewerGrid,Mode=OneWay}">
                            <FlowDocument
                                    x:Name="ConsoleDocument"
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    PageWidth="9999"
                                    LineHeight="18">
                                <Paragraph
                                        x:Name="ConsoleParagraph"
                                        Margin="8,4"
                                        FontFamily="Consolas"
                                        FontSize="12"/>
                            </FlowDocument>
                        </FlowDocumentScrollViewer>

                        <!-- 控制台为空时的提示 -->
                        <TextBlock x:Name="ConsoleEmptyHint"
                                Text="启动服务器以查看" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Medium"
                                Visibility="Collapsed"/>
                    </Grid>

                    <!-- 浮动的控制台工具栏 (右上角固定位置) -->
                    <Border Grid.Row="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        Background="{DynamicResource LayerFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">
                        <StackPanel Orientation="Horizontal">
                            <ui:Button
                                Command="{Binding ViewModel.ClearConsoleCommand, ElementName=PageRoot}"
                                Appearance="Secondary"
                                Padding="8,4">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                                    <TextBlock Text="清空" Margin="4,0,0,0" FontSize="12"/>
                                </StackPanel>
                            </ui:Button>
                            <ui:Button
                                Command="{Binding ViewModel.CopyConsoleCommand, ElementName=PageRoot}"
                                Appearance="Secondary"
                                Padding="8,4"
                                Margin="8,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Copy24" FontSize="14"/>
                                    <TextBlock Text="复制" Margin="4,0,0,0" FontSize="12"/>
                                </StackPanel>
                            </ui:Button>
                            <CheckBox
                                IsChecked="{Binding ViewModel.AutoScroll, ElementName=PageRoot, Mode=TwoWay}"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center">
                                自动滚动
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- 浮动的命令输入区域 (底部居中固定位置) -->
                    <Border Grid.Row="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,16"
                        Background="{DynamicResource LayerFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ui:TextBox Grid.Column="0"
                                Text="{Binding ViewModel.CommandInput, ElementName=PageRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="输入命令..."
                                KeyDown="OnCommandKeyDown"
                                IsEnabled="{Binding ViewModel.IsRunning, ElementName=PageRoot}"
                                MinWidth="300"
                                Height="36"/>

                            <ui:Button Grid.Column="1"
                                Command="{Binding ViewModel.SendCommandCommand, ElementName=PageRoot}"
                                Margin="8,0,0,0"
                                IsEnabled="{Binding ViewModel.IsRunning, ElementName=PageRoot}"
                                Height="36"
                                Padding="16,0">
                                发送
                            </ui:Button>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 插件管理 -->
            <TabItem HeaderTemplate="{StaticResource PluginTabHeaderTemplate}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,16,16,12">
                        <TextBlock Text="插件管理" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
                        <ui:Button 
                            Command="{Binding ViewModel.RefreshPluginsCommand, ElementName=PageRoot}"
                            Margin="16,0,0,0"
                            Appearance="Secondary">
                            <ui:SymbolIcon Symbol="ArrowSync24"/>
                        </ui:Button>
                        <ui:Button 
                            Command="{Binding ViewModel.OpenPluginsFolderCommand, ElementName=PageRoot}"
                            Margin="8,0,0,0"
                            Content="打开插件目录"
                            Appearance="Secondary">
                        </ui:Button>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" Margin="16,0,16,16">
                        <ItemsControl ItemsSource="{Binding ViewModel.Plugins, ElementName=PageRoot}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}" 
                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}" 
                                        BorderThickness="1" 
                                        CornerRadius="8" 
                                        Margin="0,4,0,8"
                                        Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 插件名称和版本 -->
                                            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                                                    <TextBlock Text=" v" VerticalAlignment="Bottom"/>
                                                    <TextBlock Text="{Binding Version}" VerticalAlignment="Bottom" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- 插件描述 -->
                                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                                                Text="{Binding Description}" 
                                                TextWrapping="Wrap" 
                                                FontSize="12" 
                                                Margin="0,0,0,8"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                                            <!-- 插件作者 -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" 
                                                Text="{Binding Authors}" 
                                                FontSize="11" 
                                                Margin="0,0,8,8"
                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

                                            <!-- 按钮组 -->
                                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <ui:Button 
                                                    Command="{Binding ViewModel.OpenPluginDataFolderCommand, ElementName=PageRoot}"
                                                    CommandParameter="{Binding}"
                                                    Content="打开数据目录"
                                                    Margin="0,0,4,0"
                                                    Appearance="Secondary"
                                                    Padding="8,4"
                                                    FontSize="11"/>
                                                <ui:Button 
                                                    Command="{Binding ViewModel.TogglePluginEnabledCommand, ElementName=PageRoot}"
                                                    CommandParameter="{Binding}"
                                                    Content="{Binding IsEnabled, Converter={StaticResource BooleanToEnableTextConverter}}"
                                                    Margin="0,0,4,0"
                                                    Appearance="{Binding IsEnabled, Converter={StaticResource BooleanToAppearanceConverter}}"
                                                    Padding="8,4"
                                                    FontSize="11"/>
                                                <ui:Button 
                                                    Command="{Binding ViewModel.DeletePluginCommand, ElementName=PageRoot}"
                                                    CommandParameter="{Binding}"
                                                    Content="删除"
                                                    Margin="0,0,0,0"
                                                    Appearance="Caution"
                                                    Padding="8,4"
                                                    FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- 服务器配置 -->
            <TabItem Header="实例配置">
                <ScrollViewer>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="16">
                            <TextBlock Text="服务器设置" FontSize="16" FontWeight="Medium" Margin="0,0,0,12"/>

                            <ui:Card Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="内存设置" FontWeight="Medium" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="最小内存 (MB)" Margin="0,0,0,4"/>
                                            <ui:TextBox Text="{Binding ViewModel.EditMinMemory, ElementName=PageRoot, Mode=TwoWay}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="最大内存 (MB)" Margin="0,0,0,4"/>
                                            <ui:TextBox Text="{Binding ViewModel.EditMaxMemory, ElementName=PageRoot, Mode=TwoWay}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ui:Card>

                            <ui:Card Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="JDK 路径" FontWeight="Medium" Margin="0,0,0,8"/>
                                    <ui:TextBox Text="{Binding ViewModel.EditJdkPath, ElementName=PageRoot, Mode=TwoWay}" 
                                        PlaceholderText="留空使用全局默认 JDK"/>
                                </StackPanel>
                            </ui:Card>

                            <ui:Button 
                                Command="{Binding ViewModel.SaveSettingsCommand, ElementName=PageRoot}"
                                Appearance="Primary"
                                HorizontalAlignment="Left">
                                保存设置
                            </ui:Button>
                            <Button>
                                打开实例目录
                            </Button>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- server.properties -->
            <TabItem Header="server.properties">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="server.properties" FontSize="16" FontWeight="Medium" Margin="16,16,16,12"/>

                    <DataGrid Grid.Row="1"
                        ItemsSource="{Binding ViewModel.ServerProperties, ElementName=PageRoot}"
                        AutoGenerateColumns="False"
                        IsReadOnly="False"
                        CanUserAddRows="True"
                        CanUserDeleteRows="True"
                        GridLinesVisibility="Horizontal"
                        Margin="16,0,16,16">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="属性名" Binding="{Binding Key, Mode=OneWay}" Width="*"/>
                            <DataGridTemplateColumn Header="值" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Value,Mode=TwoWay}"></TextBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>