<ui:ContentDialog
  x:Class="SimplyMinecraftServerManager.Views.Pages.NewInstanceDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:local="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
  xmlns:vm="clr-namespace:SimplyMinecraftServerManager.ViewModels.Pages"
  d:DataContext="{d:DesignInstance vm:NewInstanceDialogViewModel , IsDesignTimeCreatable=False}"
  d:DesignHeight="600"
  d:DesignWidth="480"
  Title="新建实例"
  MaxWidth="500"
  MinWidth="400"
  HorizontalAlignment="Center"
  VerticalAlignment="Center"
  Background="{DynamicResource ApplicationBackgroundBrush}"
  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
  BorderThickness="1"
  mc:Ignorable="d"
>
    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="6"
            Padding="24"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1">
        <Grid MinWidth="350" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="实例名称" FontWeight="Medium" Margin="0,0,0,4"/>
            <ui:TextBox Text="{Binding InstanceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="输入名称"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="服务端类型" FontWeight="Medium" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding ServerTypes}"
                SelectedItem="{Binding ServerType, Mode=TwoWay}"
                Width="350"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Minecraft 版本" FontWeight="Medium" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding AvailableVersions}"
                SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                IsEditable="False"
                Width="350"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="服务端JAR文件" FontWeight="Medium" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:TextBox Grid.Column="0" 
                    Text="{Binding CustomJarPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="使用自定义JAR文件路径（可选）"
                    IsEnabled="{Binding UseCustomJar, Mode=TwoWay}"/>
                <ui:Button Grid.Column="1" 
                    Command="{Binding BrowseCustomJarCommand}"
                    Margin="8,0,0,0"
                    Appearance="Secondary">
                    <ui:SymbolIcon Symbol="Folder24"/>
                </ui:Button>
            </Grid>
            <CheckBox Margin="0,8,0,0"
                Content="使用自定义JAR文件（不自动下载）"
                IsChecked="{Binding UseCustomJar, Mode=TwoWay}"/>
        </StackPanel>

        <!-- JDK 版本 -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Text="JDK 版本" FontWeight="Medium" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding AvailableJdks}"
                SelectedItem="{Binding SelectedJdk, Mode=TwoWay}"
                DisplayMemberPath="DisplayName"
                IsEditable="False"
                Width="350"/>
        </StackPanel>

        <!-- 内存设置 -->
        <Grid Grid.Row="5" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="最小内存 (MB)" FontWeight="Medium" Margin="0,0,0,4"/>
                <ui:TextBox Text="{Binding MinMemory, Mode=TwoWay}"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="最大内存 (MB)" FontWeight="Medium" Margin="0,0,0,4"/>
                <ui:TextBox Text="{Binding MaxMemory, Mode=TwoWay}"/>
            </StackPanel>
        </Grid>

        <!-- 状态消息 -->
        <TextBlock Grid.Row="6" 
            Text="{Binding StatusMessage}" 
            Foreground="{DynamicResource SystemFillColorCautionBrush}"
            Margin="0,0,0,8"
            TextWrapping="Wrap"
            Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- 加载指示器 -->
        <ui:ProgressRing Grid.Row="7" 
            IsIndeterminate="True" 
            Visibility="{Binding IsCreating, Converter={StaticResource BooleanToVisibilityConverter}}"
            Width="24" Height="24"
            HorizontalAlignment="Center"
            Margin="0,0,0,8"/>

        <!-- 按钮 -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <ui:Button 
                Content="取消" 
                Appearance="Secondary" 
                Click="OnCloseButtonClick"
                Margin="0,0,8,0"/>
            <ui:Button 
                Content="创建" 
                Appearance="Primary" 
                Click="OnPrimaryButtonClick"/>
        </StackPanel>
    </Grid>
    </Border>
</ui:ContentDialog>