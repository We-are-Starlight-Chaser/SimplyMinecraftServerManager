<ui:ContentDialog x:Class="SimplyMinecraftServerManager.Views.Pages.ServerPingerDialog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:dialogs="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
      xmlns:helpers="clr-namespace:SimplyMinecraftServerManager.Helpers"
      mc:Ignorable="d" 
      MaxWidth="900" MinWidth="600"
      MinHeight="500" MaxHeight="800"
      Title="服务器联通性检测"
      PrimaryButtonText="关闭"
      IsPrimaryButtonEnabled="True"
      d:DataContext="{d:DesignInstance Type=dialogs:ServerPingerDialog, IsDesignTimeCreatable=False}"
      Background="{DynamicResource ApplicationBackgroundBrush}"
      BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
      BorderThickness="1">
    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="12" Padding="35"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="{Binding ViewModel.StatusText}" 
                       FontSize="14" FontWeight="SemiBold" 
                       Margin="0,0,0,16"
                       TextOptions.TextFormattingMode="Display">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ViewModel.StatusText}" Value="就绪">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- 服务器配置区 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,24">
                <ui:TextBox Width="200" Padding="8" Margin="0,0,12,0"
                            PlaceholderText="127.0.0.1"
                            Text="{Binding ViewModel.Ip, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Center"/>

                <ui:TextBox Width="100" Padding="8" Margin="0,0,12,0"
                            PlaceholderText="25565"
                            Text="{Binding ViewModel.Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Center"/>
                <ui:Button Appearance="Primary"
                           Content="连接" 
                           Padding="12,6"
                           Command="{Binding ViewModel.PingServerCommand}"/>
            </StackPanel>

            <!-- 主内容区 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="128" Height="128" 
                        Background="{DynamicResource SubtleFillColorSecondaryBrush}" 
                        CornerRadius="8" Margin="0,0,16,0" ClipToBounds="True">
                    <Image Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Source="{Binding ViewModel.ServerIconSource}"/>
                </Border>

                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock
                                   helpers:McColorBinder.Motd="{Binding ViewModel.Motd}"
                                   FontSize="16" FontWeight="Bold" Margin="0,0,0,12"
                                   TextWrapping="Wrap" TextOptions.TextFormattingMode="Display"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="People24" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center" TextOptions.TextFormattingMode="Display">
                                    <Run Text="在线: "/>
                                    <Run Text="{Binding ViewModel.OnlinePlayers, Mode=OneWay}"/>
                                    <Run Text="/"/>
                                    <Run Text="{Binding ViewModel.MaxPlayers, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Timer24" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center" TextOptions.TextFormattingMode="Display">
                                    <Run Text="延迟: "/>
                                    <Run Text="{Binding ViewModel.LatencyMs, Mode=OneWay}"/>
                                    <Run Text="ms"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <GroupBox Header="在线玩家" Margin="0,0,0,12" Padding="8">
                            <ItemsControl ItemsSource="{Binding ViewModel.Players}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <ui:SymbolIcon Symbol="Person24" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <StackPanel>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextOptions.TextFormattingMode="Display">
                                <Run Text="版本: "/><Run Text="{Binding ViewModel.VersionName, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextOptions.TextFormattingMode="Display">
                                <Run Text="协议: "/><Run Text="{Binding ViewModel.ProtocolVersion, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
            <Button Content="退出" Grid.Row="3" HorizontalAlignment="Right" Click="Button_Click"/>
        </Grid>
    </Border>
</ui:ContentDialog>