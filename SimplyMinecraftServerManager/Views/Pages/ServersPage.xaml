<Page
  x:Class="SimplyMinecraftServerManager.Views.Pages.ServersPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="服务端管理"
  d:DataContext="{d:DesignInstance local:ServersPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="600"
  d:DesignWidth="900"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- 实例列表 -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="服务器实例" FontSize="20" FontWeight="Medium" VerticalAlignment="Center"/>
                <ui:Button 
                    Command="{Binding ViewModel.RefreshInstancesCommand}"
                    Margin="16,0,0,0"
                    Appearance="Secondary">
                    <ui:SymbolIcon Symbol="ArrowSync24"/>
                </ui:Button>
            </StackPanel>

            <TextBlock Grid.Row="1" Text="{Binding ViewModel.StatusMessage}" Margin="0,0,0,8"/>

            <ListView Grid.Row="2" 
                ItemsSource="{Binding ViewModel.Instances}"
                VirtualizingStackPanel.IsVirtualizing="True"
                VirtualizingStackPanel.VirtualizationMode="Recycling"
                ScrollViewer.IsDeferredScrollingEnabled="True">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,8" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 状态指示器 -->
                                <Border Grid.Column="0" 
                                    Width="12" Height="12" 
                                    CornerRadius="6"
                                    Background="{Binding StatusColor}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0"/>

                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="16"/>
                                        <Border Background="{DynamicResource AccentFillColorDisabledBrush}" 
                                            CornerRadius="4" Margin="8,0,0,0" Padding="6,2">
                                            <TextBlock Text="{Binding ServerType}" FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="MC " FontSize="12"/>
                                        <TextBlock Text="{Binding MinecraftVersion}" FontSize="12"/>
                                        <TextBlock Text=" | 内存: " FontSize="12"/>
                                        <TextBlock Text="{Binding MinMemoryMb}" FontSize="12"/>
                                        <TextBlock Text="-" FontSize="12"/>
                                        <TextBlock Text="{Binding MaxMemoryMb}" FontSize="12"/>
                                        <TextBlock Text=" MB" FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding StatusText}" FontSize="11" 
                                        Foreground="{Binding StatusColor}" Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- 操作按钮 -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:Button 
                                        Command="{Binding ViewModel.StartInstanceCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Appearance="Success"
                                        IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                        Margin="0,0,4,0">
                                        <ui:SymbolIcon Symbol="Play24"/>
                                    </ui:Button>
                                    <ui:Button 
                                        Command="{Binding ViewModel.StopInstanceCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Appearance="Danger"
                                        IsEnabled="{Binding IsRunning}"
                                        Margin="0,0,4,0">
                                        <ui:SymbolIcon Symbol="Stop24"/>
                                    </ui:Button>
                                    <ui:Button 
                                        Command="{Binding ViewModel.DeleteInstanceCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Appearance="Secondary">
                                        <ui:SymbolIcon Symbol="Delete24"/>
                                    </ui:Button>
                                </StackPanel>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- 新建实例面板 -->
        <ui:Card Grid.Column="1" Padding="16" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="新建实例" FontSize="16" FontWeight="Medium" Margin="0,0,0,16"/>

                <TextBlock Text="实例名称" Margin="0,0,0,4"/>
                <ui:TextBox Text="{Binding ViewModel.NewInstanceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="输入名称"/>

                <TextBlock Text="服务端类型" Margin="0,12,0,4"/>
                <ComboBox SelectedItem="{Binding ViewModel.NewInstanceServerType, Mode=TwoWay}" Width="280" HorizontalAlignment="Left">
                    <ComboBoxItem Content="paper"/>
                    <ComboBoxItem Content="purpur"/>
                    <ComboBoxItem Content="leaves"/>
                    <ComboBoxItem Content="leaf"/>
                </ComboBox>

                <TextBlock Text="Minecraft 版本" Margin="0,12,0,4"/>
                <ComboBox 
                    ItemsSource="{Binding ViewModel.AvailableMinecraftVersions}"
                    SelectedItem="{Binding ViewModel.NewInstanceMinecraftVersion, Mode=TwoWay}"
                    Width="280" HorizontalAlignment="Left"/>

                <TextBlock Text="JDK 版本" Margin="0,12,0,4"/>
                <ComboBox 
                    ItemsSource="{Binding ViewModel.AvailableJdks}"
                    SelectedItem="{Binding ViewModel.SelectedJdk, Mode=TwoWay}"
                    DisplayMemberPath="DisplayName"
                    Width="280" HorizontalAlignment="Left"/>

                <TextBlock Text="最小内存 (MB)" Margin="0,12,0,4"/>
                <ui:TextBox Text="{Binding ViewModel.NewInstanceMinMemory, Mode=TwoWay}" Width="280" HorizontalAlignment="Left"/>

                <TextBlock Text="最大内存 (MB)" Margin="0,12,0,4"/>
                <ui:TextBox Text="{Binding ViewModel.NewInstanceMaxMemory, Mode=TwoWay}" Width="280" HorizontalAlignment="Left"/>

                <ui:Button 
                    Command="{Binding ViewModel.CreateNewInstanceCommand}"
                    Appearance="Primary"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Add24"/>
                        <TextBlock Text="创建实例" Margin="8,0,0,0"/>
                    </StackPanel>
                </ui:Button>
            </StackPanel>
        </ui:Card>
    </Grid>
</Page>