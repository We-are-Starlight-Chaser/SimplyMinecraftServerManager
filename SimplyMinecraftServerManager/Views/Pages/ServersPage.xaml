<Page
  x:Class="SimplyMinecraftServerManager.Views.Pages.ServersPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="服务端管理"
  d:DataContext="{d:DesignInstance local:ServersPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="600"
  d:DesignWidth="900"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
  x:Name="PageRoot"
>
    <Page.Resources>
        <Style x:Key="InstanceCardStyle" TargetType="Border">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="8,0,8,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:SymbolIcon Symbol="Server24" FontSize="28" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" Margin="0,0,12,0"/>
                <TextBlock Text="服务器实例" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <ui:Button Command="{Binding ViewModel.RefreshInstancesCommand, ElementName=PageRoot}" Margin="16,0,0,0" Appearance="Transparent" ToolTip="刷新列表">
                    <ui:SymbolIcon Symbol="ArrowSync24" FontSize="18"/>
                </ui:Button>
            </StackPanel>

            <ui:Button Grid.Column="1" Command="{Binding ViewModel.CreateNewInstanceCommand, ElementName=PageRoot}" Appearance="Primary">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Add24" FontSize="16"/>
                    <TextBlock Text="新建实例" Margin="8,0,0,0" FontWeight="Medium"/>
                </StackPanel>
            </ui:Button>
        </Grid>

        <ui:Card Grid.Row="1" Margin="0,0,0,16" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="实例总览" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ViewModel.StatusMessage, ElementName=PageRoot}" Margin="0,4,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <Border Grid.Column="1" Padding="14,10" CornerRadius="14" Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                    <TextBlock Text="{Binding ViewModel.Instances.Count, ElementName=PageRoot, StringFormat='共 {0} 个实例'}" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </ui:Card>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding ViewModel.Instances, ElementName=PageRoot}" HorizontalAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource InstanceCardStyle}"
                            Width="360"
                            Height="220"
                            Margin="6,6,6,0"
                            CornerRadius="12"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            RenderTransformOrigin="0.5,0.5"
                            MouseLeftButtonDown="OnCardClick">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="{Binding StatusColor}" CornerRadius="4,0,0,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#4CAF50" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <Grid Grid.Column="1" Margin="16,14,14,14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" FontSize="16" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                                        <Border Grid.Column="1" CornerRadius="10" Padding="10,4" Background="{Binding StatusColor}" Opacity="0.9">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="{Binding IsRunning, Converter={StaticResource RunningToIconConverter}}" FontSize="10" Foreground="White" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding StatusText}" FontSize="10" FontWeight="SemiBold" Foreground="White" Margin="5,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border CornerRadius="6" Padding="10,4" Margin="0,0,6,0" Background="{DynamicResource AccentFillColorSecondaryBrush}">
                                            <TextBlock Text="{Binding ServerType}" FontSize="11" Foreground="White" FontWeight="Medium"/>
                                        </Border>
                                        <Border CornerRadius="6" Padding="10,4" Background="{DynamicResource AccentFillColorDefaultBrush}">
                                            <TextBlock Text="{Binding MinecraftVersion}" FontSize="11" Foreground="White" FontWeight="Medium"/>
                                        </Border>
                                    </StackPanel>

                                    <Border Grid.Row="2" Height="1" Background="{DynamicResource DividerStrokeColorDefaultBrush}" Margin="0,0,0,12"/>

                                    <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                                        <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,6,0"/>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                            <Run Text="{Binding MinMemoryMb, Mode=OneWay}"/>
                                            <Run Text="-"/>
                                            <Run Text="{Binding MaxMemoryMb, Mode=OneWay}"/>
                                            <Run Text="MB"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                                        <ui:SymbolIcon Symbol="Globe24" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding ServerAddress}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontFamily="Consolas"/>
                                    </StackPanel>

                                    <Grid Grid.Row="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <ui:Button Command="{Binding ViewModel.StartInstanceCommand, ElementName=PageRoot}" CommandParameter="{Binding}" Appearance="Success"
                                                Height="34" Padding="12,0" Visibility="{Binding IsRunning, Converter={StaticResource InverseBooleanToVisibilityConverter}}" ToolTip="启动服务器">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Play24" FontSize="14"/>
                                                    <TextBlock Text="启动" Margin="6,0,0,0" FontWeight="Medium"/>
                                                </StackPanel>
                                            </ui:Button>

                                            <ui:Button Command="{Binding ViewModel.StopInstanceCommand, ElementName=PageRoot}" CommandParameter="{Binding}" Appearance="Secondary"
                                                Height="34" Padding="12,0" Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="优雅停止服务器">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Stop24" FontSize="14"/>
                                                    <TextBlock Text="停止" Margin="6,0,0,0" FontWeight="Medium"/>
                                                </StackPanel>
                                            </ui:Button>

                                            <ui:Button Command="{Binding ViewModel.TerminateInstanceCommand, ElementName=PageRoot}" CommandParameter="{Binding}" Appearance="Danger"
                                                Height="34" Padding="12,0" Margin="6,0,0,0" Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="强制终止服务器进程">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                                                    <TextBlock Text="终止" Margin="6,0,0,0" FontWeight="Medium"/>
                                                </StackPanel>
                                            </ui:Button>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <ui:Button Command="{Binding ViewModel.DeleteInstanceCommand, ElementName=PageRoot}" CommandParameter="{Binding}" Appearance="Transparent"
                                                Height="34" Width="34" Padding="0" ToolTip="删除实例">
                                                <ui:SymbolIcon Symbol="Delete24" FontSize="16" Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                                            </ui:Button>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
            Visibility="{Binding ViewModel.Instances.Count, ElementName=PageRoot, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=inverse}">
            <Border Width="80" Height="80" CornerRadius="20" Background="{DynamicResource SubtleFillColorTertiaryBrush}" HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="Server24" FontSize="36" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
            </Border>
            <TextBlock Text="暂无服务器实例" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                HorizontalAlignment="Center" Margin="0,20,0,0"/>
            <TextBlock Text="点击右上角「新建实例」按钮创建您的第一个服务器" FontSize="13"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</Page>
