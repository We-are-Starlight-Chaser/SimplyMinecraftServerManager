<Page
  x:Class="SimplyMinecraftServerManager.Views.Pages.DownloadsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="下载任务"
  d:DataContext="{d:DesignInstance local:DownloadsPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="600"
  d:DesignWidth="900"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="下载任务" FontSize="24" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <Run Text="{Binding ViewModel.ActiveCount, Mode=OneWay}"/>
                        <Run Text="个进行中"/>
                    </TextBlock>
                    <TextBlock Text=" | " Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <Run Text="{Binding ViewModel.CompletedCount, Mode=OneWay}"/>
                        <Run Text="个已完成"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <ui:Button 
                    Command="{Binding ViewModel.CancelAllTasksCommand}"
                    Appearance="Secondary"
                    Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Dismiss24"/>
                        <TextBlock Text="全部取消" Margin="8,0,0,0"/>
                    </StackPanel>
                </ui:Button>
                <ui:Button 
                    Command="{Binding ViewModel.ClearCompletedCommand}"
                    Appearance="Secondary">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Delete24"/>
                        <TextBlock Text="清除已完成" Margin="8,0,0,0"/>
                    </StackPanel>
                </ui:Button>
            </StackPanel>
        </Grid>

        <!-- 任务列表 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ViewModel.DownloadTasks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,8" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <!-- 文件名和状态 -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}" 
                                            FontWeight="Medium" FontSize="14"
                                            TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                                        <Border Grid.Column="2" 
                                            Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="4" Padding="8,2" Margin="8,0,0,0"
                                            VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Status}" FontSize="12"/>
                                        </Border>
                                    </Grid>

                                    <!-- 进度条 -->
                                    <ProgressBar Value="{Binding Progress}" Maximum="100" 
                                        Height="6" Margin="0,8,0,4"/>

                                    <!-- 大小和速度 -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding SizeInfo}" 
                                            FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Speed}" 
                                            FontSize="12" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                            FontWeight="Medium"/>
                                    </Grid>
                                </StackPanel>

                                <!-- 操作按钮 -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="16,0,0,0">
                                    <!-- 取消按钮（仅下载中显示） -->
                                    <ui:Button 
                                        Command="{Binding DataContext.ViewModel.CancelTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Appearance="Secondary"
                                        Height="32" Width="32"
                                        Padding="0"
                                        Margin="0,0,4,0"
                                        ToolTip="取消下载"
                                        Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                                    </ui:Button>
                                    <!-- 移除按钮 -->
                                    <ui:Button 
                                        Command="{Binding DataContext.ViewModel.RemoveTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Appearance="Secondary"
                                        Height="32" Width="32"
                                        Padding="0"
                                        ToolTip="移除">
                                        <ui:SymbolIcon Symbol="Delete24" FontSize="14"/>
                                    </ui:Button>
                                </StackPanel>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 空状态提示 -->
        <StackPanel Grid.Row="1" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center"
            Visibility="{Binding ViewModel.DownloadTasks.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=inverse}">
            <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="48" 
                Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
            <TextBlock Text="暂无下载任务" 
                FontSize="16" 
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center" Margin="0,16,0,0"/>
            <TextBlock Text="前往「下载」页面开始下载服务端、插件或JDK" 
                FontSize="12" 
                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</Page>