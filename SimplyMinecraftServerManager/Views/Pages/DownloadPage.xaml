<Page
  x:Class="SimplyMinecraftServerManager.Views.Pages.DownloadPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:SimplyMinecraftServerManager.Controls"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="下载"
  d:DataContext="{d:DesignInstance local:DownloadPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="600"
  d:DesignWidth="900"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
    <Grid>
        <TabControl>
            <TabItem Header="服务端">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="8" Margin="0,0,12,0"
                                Background="{Binding ViewModel.CurrentPlatformName, Converter={StaticResource PlatformNameToColorConverter}}"
                                VerticalAlignment="Center">
                                <TextBlock Text="{Binding ViewModel.CurrentPlatformName, Converter={StaticResource PlatformNameToInitialConverter}}" 
                                    FontSize="20" FontWeight="Bold" 
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="{Binding ViewModel.CurrentPlatformName}" FontSize="18" FontWeight="Medium"/>
                                <TextBlock Text="{Binding ViewModel.CurrentPlatformDescription}" FontSize="12" 
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <ComboBox 
                                    SelectedIndex="{Binding ViewModel.SelectedServerPlatformIndex, Mode=TwoWay}"
                                    Width="140" Margin="0,0,8,0">
                                    <ComboBoxItem Content="Paper"/>
                                    <ComboBoxItem Content="Folia"/>
                                    <ComboBoxItem Content="Purpur"/>
                                    <ComboBoxItem Content="Leaves"/>
                                    <ComboBoxItem Content="Leaf"/>
                                </ComboBox>
                                <ui:Button 
                                    Command="{Binding ViewModel.LoadServerVersionsCommand}"
                                    IsEnabled="{Binding ViewModel.IsLoadingVersions, Converter={StaticResource InverseBooleanConverter}}"
                                    Appearance="Secondary">
                                    <ui:SymbolIcon Symbol="ArrowSync24"/>
                                </ui:Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Grid.Row="1" Text="{Binding ViewModel.ServerDownloadStatus}" 
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,12"/>
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ScrollViewer x:Name="ServerVersionsScrollViewer" Grid.Row="0" VerticalScrollBarVisibility="Auto" 
                                                                                                                Visibility="{Binding ViewModel.IsLoadingVersions, Converter={StaticResource InverseBooleanConverter}, FallbackValue=Visible}"
                                                                                                                ScrollChanged="OnServerVersionsScrollChanged">
                            <ItemsControl ItemsSource="{Binding ViewModel.ServerVersionCards}" 

                                                                        HorizontalAlignment="Stretch" 

                                                                        Margin="6">

                                <ItemsControl.ItemsPanel>

                                    <ItemsPanelTemplate>

                                        <UniformGrid Columns="3" HorizontalAlignment="Stretch"/>

                                    </ItemsPanelTemplate>

                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>

                                    <DataTemplate>

                                        <ui:Card Margin="6" Padding="0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0" Padding="16,12">
                                                    <Border.Background>
                                                        <MultiBinding Converter="{StaticResource ThemeAwareColorConverter}">
                                                            <Binding Path="PlatformColorLight"/>
                                                            <Binding Path="PlatformColorDark"/>
                                                        </MultiBinding>
                                                    </Border.Background>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding MinecraftVersion}" 
                                                        FontSize="28" FontWeight="Bold" Foreground="White"/>
                                                        <Border Grid.Column="1" 
                                                        Background="#33FFFFFF" 
                                                        CornerRadius="4" 
                                                        Padding="8,4"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsExperimental, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock Text="实验性" FontSize="11" Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <Border Grid.Row="1" Padding="16,12">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="构建 #" FontSize="12" 
                                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                            <TextBlock Text="{Binding LatestBuild.BuildNumber}" FontSize="12" FontWeight="Medium"/>
                                                            <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}" 
                                                            CornerRadius="4" Margin="8,0,0,0" Padding="6,2">
                                                                <TextBlock Text="{Binding ChannelTag}" FontSize="10"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding LatestBuild.FileName}" 
                                                        FontSize="11" 
                                                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                        Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- 分隔线 -->
                                                <Border Grid.Row="2" Height="1" 
                                                Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                Margin="16,0"/>

                                                <!-- 操作按钮 -->
                                                <Border Grid.Row="3" Padding="16,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <ui:Button Grid.Column="0"
                                                        Command="{Binding ViewModel.DownloadAndCreateCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Appearance="Primary"
                                                        HorizontalAlignment="Stretch">
                                                            <StackPanel Orientation="Horizontal">
                                                                <ui:SymbolIcon Symbol="Add24"/>
                                                                <TextBlock Text="下载并创建" Margin="8,0,0,0"/>
                                                            </StackPanel>
                                                        </ui:Button>

                                                        <ui:Button Grid.Column="1"
                                                        Command="{Binding ViewModel.SaveServerVersionAsCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Appearance="Secondary"
                                                        Margin="8,0,0,0"
                                                        ToolTip="另存为...">
                                                            <ui:SymbolIcon Symbol="Save24"/>
                                                        </ui:Button>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </ui:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- 加载更多按钮 -->
                        <Grid Grid.Row="1" Margin="0,16,0,0" 
                            Visibility="{Binding ViewModel.HasMoreVersions, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:Button 
                                Command="{Binding ViewModel.LoadMoreVersionsCommand}"
                                IsEnabled="{Binding ViewModel.IsLoadingMore, Converter={StaticResource InverseBooleanConverter}}"
                                HorizontalAlignment="Center"
                                Appearance="Secondary">
                                <Grid>
                                    <StackPanel x:Name="NormalContent" Orientation="Horizontal"
                                        Visibility="{Binding ViewModel.IsLoadingMore, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <ui:SymbolIcon Symbol="Add24"/>
                                        <TextBlock Text="加载更多版本" Margin="8,0,0,0"/>
                                    </StackPanel>

                                    <ui:ProgressRing x:Name="LoadingContent" Width="16" Height="16" IsIndeterminate="True"
                                        Visibility="{Binding ViewModel.IsLoadingMore, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </ui:Button>
                        </Grid>
                        <Grid Background="{DynamicResource ApplicationBackgroundBrush}"
                            Visibility="{Binding ViewModel.IsLoadingVersions, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48"/>
                                <TextBlock Text="正在加载版本列表..." 
                                    Margin="0,16,0,0" 
                                    HorizontalAlignment="Center"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="插件">
                <controls:DownloadPluginsPanel Margin="16" DataContext="{Binding ViewModel}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
