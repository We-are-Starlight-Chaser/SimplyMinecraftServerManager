<Page
  x:Class="SimplyMinecraftServerManager.Views.Pages.DownloadPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="下载"
  d:DataContext="{d:DesignInstance local:DownloadPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="600"
  d:DesignWidth="900"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 下载任务状态栏 -->
        <ui:Card Grid.Row="0" Margin="0,0,0,12" Padding="16">
            <StackPanel>
                <TextBlock Text="下载任务" FontSize="16" FontWeight="Medium" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding ViewModel.DownloadTasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Medium"/>
                                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="4" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Speed}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Status}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ui:Card>

        <!-- 主内容区域 - 使用 TabControl -->
        <TabControl Grid.Row="1">
            <!-- 服务端下载 -->
            <TabItem Header="服务端">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 平台和版本选择 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="平台:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox 
                            SelectedIndex="{Binding ViewModel.SelectedServerPlatformIndex, Mode=TwoWay}"
                            Width="120">
                            <ComboBoxItem Content="Paper"/>
                            <ComboBoxItem Content="Folia"/>
                            <ComboBoxItem Content="Purpur"/>
                            <ComboBoxItem Content="Leaves"/>
                            <ComboBoxItem Content="Leaf"/>
                        </ComboBox>

                        <TextBlock Text="版本:" VerticalAlignment="Center" Margin="16,0,8,0"/>
                        <ComboBox 
                            ItemsSource="{Binding ViewModel.MinecraftVersions}"
                            SelectedItem="{Binding ViewModel.SelectedMinecraftVersion, Mode=TwoWay}"
                            Width="100"/>

                        <ui:Button 
                            Command="{Binding ViewModel.LoadServerVersionsCommand}"
                            Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowSync24"/>
                                <TextBlock Text="刷新" Margin="4,0,0,0"/>
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>

                    <!-- 状态提示 -->
                    <TextBlock Grid.Row="1" Text="{Binding ViewModel.ServerDownloadStatus}" Margin="0,0,0,8"/>

                    <!-- 构建列表 -->
                    <ListView Grid.Row="2" 
                        ItemsSource="{Binding ViewModel.ServerBuilds}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Medium"/>
                                        <TextBlock Text="{Binding Build.MinecraftVersion}" FontSize="12"/>
                                    </StackPanel>
                                    <ui:Button Grid.Column="1" 
                                        Command="{Binding DataContext.DownloadServerBuildCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="ArrowDownload24"/>
                                            <TextBlock Text="下载" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- 插件搜索下载 -->
            <TabItem Header="插件">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 搜索栏 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:TextBox 
                            Text="{Binding ViewModel.PluginSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Width="300"
                            PlaceholderText="搜索插件..."
                            KeyDown="OnPluginSearchKeyDown"/>
                        <ui:Button 
                            Command="{Binding ViewModel.SearchPluginsCommand}"
                            Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Search24"/>
                                <TextBlock Text="搜索" Margin="4,0,0,0"/>
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>

                    <!-- 目标实例选择 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="安装到:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox 
                            ItemsSource="{Binding ViewModel.AvailableInstances}"
                            SelectedValuePath="Id"
                            SelectedValue="{Binding ViewModel.PluginTargetInstanceId, Mode=TwoWay}"
                            DisplayMemberPath="Name"
                            Width="200"/>
                        <TextBlock Text="{Binding ViewModel.PluginSearchStatus}" 
                            Margin="16,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 搜索结果 -->
                    <ListView Grid.Row="2" ItemsSource="{Binding ViewModel.PluginSearchResults}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="8" 
                                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                                        <TextBlock Text="📦" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding Title}" FontWeight="Medium" FontSize="14"/>
                                        <TextBlock Text="{Binding Description}" FontSize="12" MaxHeight="40" TextTrimming="CharacterEllipsis" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="下载: " FontSize="11"/>
                                            <TextBlock Text="{Binding Downloads}" FontSize="11"/>
                                            <TextBlock Text=" | 作者: " FontSize="11" Margin="8,0,0,0"/>
                                            <TextBlock Text="{Binding Author}" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <ui:Button Grid.Column="2" 
                                        Command="{Binding DataContext.DownloadPluginCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="ArrowDownload24"/>
                                            <TextBlock Text="下载" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- JDK 下载 -->
            <TabItem Header="JDK">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 发行版和版本选择 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="发行版:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox 
                            SelectedIndex="{Binding ViewModel.SelectedJdkDistributionIndex, Mode=TwoWay}"
                            Width="120">
                            <ComboBoxItem Content="Adoptium"/>
                            <ComboBoxItem Content="Zulu"/>
                        </ComboBox>

                        <TextBlock Text="版本:" VerticalAlignment="Center" Margin="16,0,8,0"/>
                        <ComboBox 
                            ItemsSource="{Binding ViewModel.AvailableJdkVersions}"
                            SelectedItem="{Binding ViewModel.SelectedJdkMajorVersion, Mode=TwoWay}"
                            Width="80"/>

                        <ui:Button 
                            Command="{Binding ViewModel.LoadJdkVersionsCommand}"
                            Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowSync24"/>
                                <TextBlock Text="刷新" Margin="4,0,0,0"/>
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>

                    <!-- 状态提示 -->
                    <TextBlock Grid.Row="1" Text="{Binding ViewModel.JdkDownloadStatus}" Margin="0,0,0,8"/>

                    <!-- JDK 构建列表 -->
                    <ListView Grid.Row="2" ItemsSource="{Binding ViewModel.JdkBuilds}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="Medium">
                                            <Run Text="JDK "/>
                                            <Run Text="{Binding FullVersion}"/>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding Distribution}" FontSize="12"/>
                                            <TextBlock Text=" | " FontSize="12"/>
                                            <TextBlock Text="{Binding Architecture}" FontSize="12"/>
                                            <TextBlock Text=" | " FontSize="12"/>
                                            <TextBlock Text="{Binding FileName}" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <ui:Button Grid.Column="1" 
                                        Command="{Binding DataContext.DownloadJdkCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="ArrowDownload24"/>
                                            <TextBlock Text="下载并安装" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>