<Page
  x:Class="SimplyMinecraftServerManager.Views.Pages.DashboardPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="主页"
  d:DataContext="{d:DesignInstance local:DashboardPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="600"
  d:DesignWidth="900"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
    <Grid Margin="0,0,0,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:Card Grid.Row="0" Margin="0,0,0,16" Padding="28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="88" Height="88" CornerRadius="18"
                    Background="{DynamicResource AccentFillColorSecondaryBrush}" Margin="0,0,24,0">
                    <Image Source="pack://application:,,,/Assets/Pictures/SMSM-icon-256.jpg" Width="64" Height="64"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ViewModel.WelcomeText}" FontSize="28" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ViewModel.StatisticsText}" Margin="0,8,0,0" FontSize="14"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{Binding ViewModel.JdkStatus}" Margin="0,4,0,0" FontSize="12"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                </StackPanel>

                <Border Grid.Column="2" Padding="14,10" CornerRadius="14"
                    Background="{DynamicResource SubtleFillColorSecondaryBrush}" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="管理目标" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="本地一键开服与运维" FontWeight="Medium" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ui:Card>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
            <ui:Button Command="{Binding ViewModel.NavigateToDownloadsCommand}" Margin="0,0,12,0" Padding="20" Appearance="Primary">
                <StackPanel>
                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="22"/>
                    <TextBlock Text="下载服务端或插件" Margin="0,10,0,0" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="从版本列表直接创建实例" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </ui:Button>

            <ui:Button Command="{Binding ViewModel.NavigateToServersCommand}" Margin="0,0,12,0" Padding="20" Appearance="Secondary">
                <StackPanel>
                    <ui:SymbolIcon Symbol="Server24" FontSize="22"/>
                    <TextBlock Text="管理现有实例" Margin="0,10,0,0" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="启动、停止、进入实例详情" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </ui:Button>

            <ui:Button Command="{Binding ViewModel.NavigateToSettingsCommand}" Padding="20" Appearance="Secondary">
                <StackPanel>
                    <ui:SymbolIcon Symbol="Settings24" FontSize="22"/>
                    <TextBlock Text="配置全局默认项" Margin="0,10,0,0" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="JDK、默认内存和下载策略" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </ui:Button>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="最近的服务器" FontSize="18" FontWeight="Medium" Margin="0,0,0,12"/>

                <ListView Grid.Row="1" ItemsSource="{Binding ViewModel.RecentInstances}"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Recycling"
                    ScrollViewer.IsDeferredScrollingEnabled="True">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,8" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                        Background="{DynamicResource AccentFillColorDisabledBrush}">
                                        <ui:SymbolIcon Symbol="Server24" FontSize="20"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="14"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Border Padding="8,3" CornerRadius="8" Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                                <TextBlock Text="{Binding ServerType}" FontSize="11"/>
                                            </Border>
                                            <Border Padding="8,3" CornerRadius="8" Margin="8,0,0,0" Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                                <TextBlock Text="{Binding MinecraftVersion}" FontSize="11"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <ui:Card Grid.Column="1" Padding="18" VerticalAlignment="Top">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="Alert24"/>
                        <TextBlock Text="公告" FontSize="18" FontWeight="Medium" Margin="8,0,0,0"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding ViewModel.Announcements}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ui:Card>
        </Grid>
    </Grid>
</Page>
