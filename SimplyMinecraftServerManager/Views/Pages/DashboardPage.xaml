 <Page
  x:Class="SimplyMinecraftServerManager.Views.Pages.DashboardPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="主页"
  d:DataContext="{d:DesignInstance local:DashboardPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="600"
  d:DesignWidth="900"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 欢迎区域 -->
        <ui:Card Grid.Row="0" Margin="0,0,0,16" Padding="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Border Grid.Column="0" Width="80" Height="80" CornerRadius="12" 
                    Background="{DynamicResource AccentFillColorDefaultBrush}" Margin="0,0,24,0">
                    <Image Source="pack://application:,,,/Assets/wpfui-icon-256.png" 
                        Width="64" Height="64"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ViewModel.WelcomeText}" FontSize="24" FontWeight="Medium"/>
                    <TextBlock Text="{Binding ViewModel.StatisticsText}" 
                        Margin="0,8,0,0" FontSize="14"/>
                    <TextBlock Text="{Binding ViewModel.JdkStatus}" 
                        Margin="0,4,0,0" FontSize="12"/>
                </StackPanel>
            </Grid>
        </ui:Card>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 快捷操作和最近实例 -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 快捷操作 -->
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="快捷操作" FontSize="18" FontWeight="Medium" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Command="{Binding ViewModel.NavigateToSiteCommand}" CommandParameter="https://wasc.qzz.io/products/smsm" Appearance="Secondary">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Globe24"/>
                                <TextBlock Text="产品主页" Margin="8,0,0,0"/>
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Command="{Binding ViewModel.NavigateToSiteCommand}" CommandParameter="https://wasc.qzz.io/tutorials/smsm" Margin="8,0,0,0" Appearance="Secondary">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Book24"/>
                                <TextBlock Text="使用教程" Margin="8,0,0,0"/>
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Command="{Binding ViewModel.NavigateToSiteCommand}" CommandParameter="https://github.com/We-are-Starlight-Chaser/SimplyMinecraftServerManager" Margin="8,0,0,0" Appearance="Secondary">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Link24"/>
                                <TextBlock Text="GitHub" Margin="8,0,0,0"/>
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </StackPanel>

                <!-- 最近实例 -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="最近的服务器" FontSize="18" FontWeight="Medium" Margin="0,0,0,12"/>

                    <ListView Grid.Row="1" ItemsSource="{Binding ViewModel.RecentInstances}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <ui:Card Margin="0,0,0,8" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                            Background="{DynamicResource AccentFillColorDisabledBrush}">
                                            <ui:SymbolIcon Symbol="Server24" FontSize="20"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="14"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding ServerType}" FontSize="12"/>
                                                <TextBlock Text=" | " FontSize="12"/>
                                                <TextBlock Text="{Binding MinecraftVersion}" FontSize="12"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </ui:Card>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>

            <!-- 公告栏 -->
            <ui:Card Grid.Column="1" Padding="16" VerticalAlignment="Top">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="Alert24"/>
                        <TextBlock Text="公告" FontSize="18" FontWeight="Medium" Margin="8,0,0,0"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding ViewModel.Announcements}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" 
                                    BorderThickness="0,0,0,1" Padding="0,8">
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ui:Card>
        </Grid>
    </Grid>
</Page>