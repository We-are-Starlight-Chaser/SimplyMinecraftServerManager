 <Page
  x:Class="SimplyMinecraftServerManager.Views.Pages.DashboardPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
  xmlns:controls="clr-namespace:SimplyMinecraftServerManager.Controls"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="DashboardPage"
  d:DataContext="{d:DesignInstance local:DashboardPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
    <!-- 外层Grid：使用Star行高减少Auto布局的性能开销，增加统一内边距 -->
    <Grid Cursor="">
        <Grid.RowDefinitions>
            <!-- 替换过多Auto行高，仅关键区域用Auto，其余用Star/固定值，减少布局重算 -->
            <RowDefinition Height="Auto"/>
            <!-- 欢迎区域 -->
            <RowDefinition Height="40"/>
            <!-- 帮助标题 -->
            <RowDefinition Height="40"/>
            <!-- 帮助链接 -->
            <RowDefinition Height="40"/>
            <!-- 新闻标题 -->
            <RowDefinition Height="*"/>
            <!-- 新闻内容（占剩余空间） -->
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- 图片：使用Image替代ImageIcon（轻量），增加圆角避免生硬 -->
            <Image Source="pack://application:,,,/Assets/Pictures/SMSM-icon-256.jpg" 
                       Width="60" Height="60" 
                       Stretch="UniformToFill" 
                       HorizontalAlignment="Left"/>
            <!-- 欢迎文本：优化字体、绑定模式（OneWay减少双向开销）、增加柔和效果 -->
            <TextBlock Grid.Column="1"
                           FontSize="20" 
                           FontWeight="Medium"
                           Text="{Binding ViewModel.UserName, Mode=OneWay, StringFormat=Hi\, {0}! 今天有什么想做的吗？}" 
                           VerticalAlignment="Center"
                           Margin="15 0 0 0"/>
        </Grid>

        <!-- 2. 帮助标题：优化字体层级、颜色 -->
        <TextBlock Grid.Row="1"
                   Text="不知道如何使用？" 
                   FontSize="22" 
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Margin="0 0 0 5"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 0 5">
            <ui:Anchor NavigateUri="https://wasc.qzz.io/tutorials/smsm" 
                       Padding="8 4" 
                       CornerRadius="6">
                使用教程
            </ui:Anchor>
            <ui:Anchor NavigateUri="https://wasc.qzz.io/docs/smsm" 
                       Margin="10 0 0 0"
                       Padding="8 4" 
                       CornerRadius="6">
                产品文档
            </ui:Anchor>
        </StackPanel>
        <TextBlock Grid.Row="3"
                   Text="或者，来看看以下新闻：" 
                   FontSize="22" 
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Margin="0 0 0 5"/>


        <TextBox Text="{Binding ViewModel.News, UpdateSourceTrigger=PropertyChanged}"
                     Grid.Row="4"
                     FontSize="14"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Padding="0"/>
    </Grid>
</Page>