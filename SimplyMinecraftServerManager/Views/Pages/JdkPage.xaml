<Page
  x:Class="SimplyMinecraftServerManager.Views.Pages.JdkPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="JDK 管理"
  d:DataContext="{d:DesignInstance local:JdkPage, IsDesignTimeCreatable=False}"
  d:DesignHeight="600"
  d:DesignWidth="900"
  ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
  ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
  mc:Ignorable="d"
>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- 已安装的 JDK 列表 -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="已安装的 JDK" FontSize="20" FontWeight="Medium" VerticalAlignment="Center"/>
                <ui:Button 
                    Command="{Binding ViewModel.RefreshCommand}"
                    Margin="16,0,0,0"
                    Appearance="Secondary">
                    <ui:SymbolIcon Symbol="ArrowSync24"/>
                </ui:Button>
            </StackPanel>

            <TextBlock Grid.Row="1" Text="{Binding ViewModel.StatusMessage}" Margin="0,0,0,8"/>

            <ListView Grid.Row="2" ItemsSource="{Binding ViewModel.InstalledJdks}"
                VirtualizingStackPanel.IsVirtualizing="True"
                VirtualizingStackPanel.VirtualizationMode="Recycling"
                ScrollViewer.IsDeferredScrollingEnabled="True">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,8" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="Medium" FontSize="16">
                                            <Run Text="JDK "/>
                                            <Run Text="{Binding MajorVersion, Mode=OneWay}"/>
                                        </TextBlock>
                                        <Border Background="{DynamicResource AccentFillColorDisabledBrush}" 
                                            CornerRadius="4" Margin="8,0,0,0" Padding="6,2">
                                            <TextBlock Text="{Binding DistributionName}" FontSize="11"/>
                                        </Border>
                                        <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}" 
                                            CornerRadius="4" Margin="4,0,0,0" Padding="6,2">
                                            <TextBlock Text="{Binding Architecture}" FontSize="11"/>
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="{Binding FullVersion}" FontSize="12" Margin="0,4,0,0"/>

                                    <TextBlock Text="{Binding HomePath}" FontSize="11" 
                                        Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Text="{Binding StatusText}" FontSize="11" 
                                        Foreground="{Binding StatusColor}" Margin="0,4,0,0"/>
                                </StackPanel>

                                <ui:Button Grid.Column="1" 
                                    Command="{Binding DataContext.UninstallJdkCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}"
                                    Appearance="Secondary"
                                    VerticalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Delete24"/>
                                </ui:Button>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- 安装新 JDK 面板 -->
        <ui:Card Grid.Column="1" Padding="16" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="安装新 JDK" FontSize="16" FontWeight="Medium" Margin="0,0,0,16"/>

                <TextBlock Text="发行版" Margin="0,0,0,4"/>
                <ComboBox SelectedIndex="{Binding ViewModel.SelectedJdkDistributionIndex, Mode=TwoWay}" 
                    Width="280" HorizontalAlignment="Left">
                    <ComboBoxItem Content="Adoptium (Temurin)"/>
                    <ComboBoxItem Content="Azul Zulu"/>
                </ComboBox>

                <TextBlock Text="版本" Margin="0,12,0,4"/>
                <ComboBox 
                    ItemsSource="{Binding ViewModel.AvailableJdkVersions}"
                    SelectedItem="{Binding ViewModel.SelectedJdkMajorVersion, Mode=TwoWay}"
                    Width="280" HorizontalAlignment="Left"/>

                <ui:Button 
                    Command="{Binding ViewModel.InstallJdkCommand}"
                    IsEnabled="{Binding ViewModel.IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                    Appearance="Primary"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowDownload24"/>
                        <TextBlock Text="下载并安装" Margin="8,0,0,0"/>
                    </StackPanel>
                </ui:Button>

                <TextBlock Text="{Binding ViewModel.InstallStatus}" 
                    Margin="0,12,0,0" 
                    TextWrapping="Wrap"/>

                <Separator Margin="0,16,0,16"/>

                <TextBlock Text="版本推荐" FontWeight="Medium" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" FontSize="12">
                    <Run Text="• Minecraft 1.21+ → JDK 21-25"/>
                    <LineBreak/>
                    <Run Text="• Minecraft 1.17-1.20 → JDK 17"/>
                    <LineBreak/>
                    <Run Text="• Minecraft 1.12-1.16 → JDK 11"/>
                    <LineBreak/>
                    <Run Text="• Minecraft 1.7-1.11 → JDK 8"/>
                </TextBlock>
            </StackPanel>
        </ui:Card>
    </Grid>
</Page>