<ui:ContentDialog x:Class="SimplyMinecraftServerManager.Views.Pages.ScheduledTaskDialog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SimplyMinecraftServerManager.Views.Pages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:SimplyMinecraftServerManager.Helpers"
      mc:Ignorable="d" 
      MaxWidth="380"
      MinWidth="180"
      d:DesignHeight="180"
      d:DesignWidth="380"
      Background="{DynamicResource ApplicationBackgroundBrush}"
      BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
      BorderThickness="1"
      Title="定时任务" VerticalAlignment="Center" HorizontalAlignment="Center">
    <ui:ContentDialog.Resources>
        <converters:ScheduledTaskIndexToVisibilityConverter x:Key="ScheduledTaskIndexToVisibilityConverter"/>
    </ui:ContentDialog.Resources>
    <Border
  Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
  CornerRadius="8"
  Padding="24"
  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
  BorderThickness="1"
>
        <Grid MinWidth="132">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0" SelectedIndex="0" x:Name="CBox">
                <ComboBoxItem>
                    执行命令
                </ComboBoxItem>
                <ComboBoxItem>
                    备份
                </ComboBoxItem>
                <ComboBoxItem>
                    定时重启
                </ComboBoxItem>
            </ComboBox>
            <StackPanel Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center" >
                    <StackPanel.Visibility>
                        <MultiBinding Converter="{StaticResource ScheduledTaskIndexToVisibilityConverter}">
                            <Binding Path="SelectedIndex" ElementName="CBox"/>
                        </MultiBinding>
                    </StackPanel.Visibility>
                <TextBlock FontSize="16">请输入命令：</TextBlock>
                <TextBox Margin="0,5,0,0"/>
            </StackPanel>
            </Grid>
            <Button Grid.Row="2" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="CheckMark24"/>
                    <TextBlock>确定</TextBlock>
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</ui:ContentDialog>
